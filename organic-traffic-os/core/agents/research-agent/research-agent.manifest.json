  "required_engines": ["knowledge-engine", "inventory-engine", "serp-engine"],
  "required_workflows": ["research-workflow"],
  "dependencies": { "agents": ["planning-agent"], "layers": ["connectors", "knowledge", "engines"] },
  "status": "active"
}
