{
  "name": "Headless CMS Connector",
  "version": "1.0.0",
  "description": "Base connector for Headless CMS platforms (Strapi, Directus, Sanity, Mock)",
  "type": "connector",
  "domain": "content-publishing",
  "providers": ["strapi", "directus", "sanity", "mock"],
  "actions": ["connect", "disconnect", "sync", "status", "createDraft", "updateDraft", "publish", "collections", "content"],
  "auth_required": true,
  "auth_type": "api_token",
  "rate_limit": {
    "requests_per_minute": 60,
    "concurrent": 5
  },
  "capabilities": [
    "list_collections",
    "list_content",
    "get_content_by_slug",
    "create_draft",
    "update_draft",
    "publish_content",
    "provider_adapters"
  ],
  "limitations": [
    "Requires API token for real providers",
    "Mock adapter for development/testing",
    "Schema mapping is provider-specific",
    "Featured media upload not yet supported",
    "SEO metadata integration varies by provider"
  ],
  "security": [
    "Credentials stored only in environment variables",
    "Draft creation is the default (no auto-publish)",
    "Slug conflicts are detected and blocked",
    "All actions are logged",
    "Publish requires explicit API call"
  ],
  "environment_variables": [
    "HEADLESS_CMS_PROVIDER",
    "HEADLESS_CMS_API_URL",
    "HEADLESS_CMS_API_TOKEN",
    "HEADLESS_CMS_PROJECT_ID"
  ],
  "created_at": "2026-07-02",
  "updated_at": "2026-07-02"
}
